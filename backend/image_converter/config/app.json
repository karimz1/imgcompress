      ".pdf",
      ".svg",
      ".raw",
      ".cr2",
      ".nef",
      ".arw",
      ".dng"
    ]
  },
  "storage": {
    "bytes_per_megabyte": 1048576
  },
  "features": {
    "storage_management_enabled": true,
    "show_logo": true,
    "dev_mode": false
  },
  "rembg": {
    "model_name": "u2net"
  }
}
